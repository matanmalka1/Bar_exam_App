{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bar-exam-study.local/schemas/question_import.schema.json",
  "title": "Bar Exam Question Import File",
  "type": "object",
  "additionalProperties": false,
  "required": ["exam_date", "label", "part", "part_name", "questions"],
  "properties": {
    "exam_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "part": {
      "type": "string",
      "enum": ["B", "C"]
    },
    "part_name": {
      "type": "string",
      "enum": ["דין דיוני", "דין מהותי"]
    },
    "questions": {
      "type": "array",
      "minItems": 40,
      "maxItems": 40,
      "items": {
        "$ref": "#/$defs/question"
      }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_id",
        "number",
        "status",
        "body",
        "options",
        "correct_answer",
        "reference",
        "invalidation_note"
      ],
      "properties": {
        "stable_id": {
          "type": "string",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])_[BC]_(00[1-9]|0[1-3][0-9]|040)$"
        },
        "number": {
          "type": "integer",
          "minimum": 1,
          "maximum": 40
        },
        "status": {
          "type": "string",
          "enum": ["active", "invalidated"]
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "object",
          "additionalProperties": false,
          "required": ["א", "ב", "ג", "ד"],
          "properties": {
            "א": { "type": "string", "minLength": 1 },
            "ב": { "type": "string", "minLength": 1 },
            "ג": { "type": "string", "minLength": 1 },
            "ד": { "type": "string", "minLength": 1 }
          }
        },
        "correct_answer": {
          "type": ["string", "null"],
          "enum": ["א", "ב", "ג", "ד", null]
        },
        "reference": {
          "type": "string",
          "minLength": 1
        },
        "invalidation_note": {
          "type": ["string", "null"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "active" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "correct_answer": { "enum": ["א", "ב", "ג", "ד"] },
              "invalidation_note": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "invalidated" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "correct_answer": { "type": "null" },
              "invalidation_note": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    }
  }
}
